{
  "name": "turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "install:fix": "./scripts/install-deps.sh",
    "install:clean": "./scripts/install-deps.sh --clean",
    "install:alt": "./scripts/install-deps.sh --manager npm --ignore-scripts",
    "fix-permissions": "./scripts/fix-permissions.sh",
    "migrate-to-linux": "./scripts/migrate-to-linux-fs.sh"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}